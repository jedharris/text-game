{
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "Bash",
      "mcp__claude-context",
      "Gh :*",
      "Bash(gh :*)",
      "Bash(git checkout --theirs .claude/settings.local.json)",
      "Bash(git add .claude/settings.local.json)",
      "mcp__plugin_context-mode_context-mode__execute",
      "mcp__plugin_context-mode_context-mode__search",
      "mcp__plugin_context-mode_context-mode__batch_execute",
      "mcp__plugin_context-mode_context-mode__stats",
      "mcp__plugin_context-mode_context-mode__execute_file"
    ],
    "deny": [],
    "ask": []
  },
  "model": "opusplan",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jed/Development/text-game/.claude/hooks/inject-context.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jed/Development/text-game/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
